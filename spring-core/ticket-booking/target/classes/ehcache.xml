<ehcache xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="http://www.ehcache.org/ehcache.xsd">

    <diskStore path="java.io.tmpdir"/>

    <defaultCache
            maxEntriesLocalHeap="1000"
            eternal="false"
            timeToIdleSeconds="300"
            timeToLiveSeconds="600"
            overflowToDisk="false"/>

    <cache name="ua.epam.mishchenko.ticketbooking.model.impl.TicketImpl"
           maxEntriesLocalHeap="1000"
           eternal="false"
           timeToIdleSeconds="300"
           timeToLiveSeconds="600"
           overflowToDisk="false"/>

    <cache name="ua.epam.mishchenko.ticketbooking.model.impl.UserImpl"
           maxEntriesLocalHeap="1000"
           eternal="false"
           timeToIdleSeconds="300"
           timeToLiveSeconds="600"
           overflowToDisk="false"/>

    <cache name="ua.epam.mishchenko.ticketbooking.model.impl.EventImpl"
           maxEntriesLocalHeap="1000"
           eternal="false"
           timeToIdleSeconds="300"
           timeToLiveSeconds="600"
           overflowToDisk="false"/>

    <cache name="ua.epam.mishchenko.ticketbooking.model.impl.UserAccountImpl"
           maxEntriesLocalHeap="1000"
           eternal="false"
           timeToIdleSeconds="300"
           timeToLiveSeconds="600"
           overflowToDisk="false"/>

    <cache name="default-query-results-region"
           maxEntriesLocalHeap="1000"
           timeToLiveSeconds="600"/>

    <cache name="default-update-timestamps-region"
           maxEntriesLocalHeap="1000"
           eternal="true"/>
</ehcache>